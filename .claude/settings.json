{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | bash)"
    ]
  },
  "enabledPlugins": {
    "formatter@anthropic-tools": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const d=JSON.parse(require('fs').readFileSync(0,'utf8'));const f=d.tool_response?.filePath||d.tool_input?.file_path;if(f)require('child_process').spawnSync('npx',['prettier','--write',f],{stdio:'inherit',shell:true});}catch(e){}\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}